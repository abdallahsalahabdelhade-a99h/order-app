// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String      @id @default(cuid())
  name                String
  username            String      @unique
  password            String
  role                String      @default("CUSTOMER") // SUPER_ADMIN, RESTAURANT_ADMIN, CUSTOMER
  
  // For RESTAURANT_ADMIN
  managedRestaurantId String?
  managedRestaurant   Restaurant? @relation(fields: [managedRestaurantId], references: [id])

  orders              Order[]
}

model Restaurant {
  id              String         @id @default(cuid())
  name            String
  logoUrl         String?
  deliveryNumber  String
  menuImageUrl    String?
  
  categories      MenuCategory[]
  admins          User[]         // Admins managing this restaurant
  orders          Order[]
  batches         OrderBatch[]
}

model MenuCategory {
  id           String     @id @default(cuid())
  title        String     // e.g., "سندوتشات", "وجبات"
  
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  items        MenuItem[]
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String       // e.g., "فول إسكندراني"
  price       Float
  imageUrl    String?
  
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  orderItems  OrderItem[]
}

model Order {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  totalPrice   Float
  status       String      @default("PENDING") // PENDING, BATCHED, DELIVERED
  notes        String?

  userId       String
  user         User        @relation(fields: [userId], references: [id])
  
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])

  batchId      String?
  batch        OrderBatch? @relation(fields: [batchId], references: [id])

  items        OrderItem[]
}

model OrderItem {
  id           String      @id @default(cuid())
  quantity     Int
  priceAtTime  Float

  orderId      String
  order        Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItemId   String
  menuItem     MenuItem    @relation(fields: [menuItemId], references: [id])
}

model OrderBatch {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  status       String      @default("PENDING") // PENDING, COMPLETED
  totalPrice   Float
  
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])

  orders       Order[]
}
